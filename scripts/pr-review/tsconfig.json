{
	"compilerOptions": {
		"target": "esnext",
		"module": "esnext",
		"moduleResolution": "bundler",
		"strict": true,
		"esModuleInterop": true,
		"skipLibCheck": true,
		"noEmit": true,
		"types": ["bun", "node"],
		"resolveJsonModule": true,
		"allowImportingTsExtensions": false
	},
	"include": ["./**/*.ts", "../verify-web.ts"]
}
