{
  "$schema": "https://unpkg.com/knip@5/schema.json",
  "workspaces": {
    ".": {
      "entry": ["scripts/pr-review/*.ts"],
      "project": ["scripts/pr-review/*.ts"]
    },
    "apps/server": {
      "entry": [
        "src/**/__tests__/**/*.test.ts",
        "src/__tests__/prepare.ts",
        "src/__tests__/mock-db.ts",
        "src/__tests__/setup.ts"
      ],
      "ignoreBinaries": ["tsc"],
      "project": ["src/**/*.ts"],
      "ignore": [
        "src/db/migrations/**",
        "data/**",
        "data-test/**"
      ]
    },
    "apps/client": {
      "project": ["src/**/*.{ts,tsx}"],
      "ignore": [
        "dist/**",
        "public/**",
        "src/components/ui/**"
      ]
    },
    "apps/desktop": {
      "entry": [
        "src/main/index.ts",
        "src/preload/index.ts",
        "scripts/**/*.mjs",
        "src/main/__tests__/**"
      ],
      "project": ["src/**/*.ts", "scripts/**/*.mjs"]
    },
    "packages/shared": {
      "entry": ["src/**/__tests__/**/*.test.ts"],
      "project": ["src/**/*.ts"]
    },
    "packages/plugin-sdk": {
      "project": ["src/**/*.ts"]
    }
  },
  "ignore": [
    "**/*.d.ts",
    "**/dist/**",
    "**/build/**",
    "**/node_modules/**"
  ],
  "ignoreDependencies": [],
  "ignoreExportsUsedInFile": true,
  "exclude": ["enumMembers"]
}
