{
	"$schema": "https://biomejs.dev/schemas/2.4.8/schema.json",
	"formatter": {
		"indentStyle": "tab",
		"lineWidth": 120
	},
	"css": {
		"parser": {
			"cssModules": true,
			"tailwindDirectives": true
		}
	},
	"javascript": {
		"formatter": {
			"quoteStyle": "single",
			"trailingCommas": "all"
		}
	},
	"linter": {
		"rules": {
			"recommended": true,
			"a11y": {
				"noStaticElementInteractions": "off",
				"useKeyWithClickEvents": "off",
				"useButtonType": "off",
				"useMediaCaption": "off",
				"useAltText": "off",
				"noLabelWithoutControl": "off",
				"noSvgWithoutTitle": "off",
				"noRedundantAlt": "off"
			},
			"correctness": {
				"useExhaustiveDependencies": {
					"level": "warn",
					"options": {
						"hooks": [{ "name": "useLatestRef", "stableResult": true }]
					}
				},
				"useHookAtTopLevel": "error",
				"noUnusedImports": "error",
				"noUnusedVariables": "warn"
			},
			"style": {
				"noNonNullAssertion": "off"
			},
			"suspicious": {
				"noExplicitAny": "off",
				"noArrayIndexKey": "off",
				"noAssignInExpressions": "off",
				"noImplicitAnyLet": "off",
				"useIterableCallbackReturn": "off"
			},
			"complexity": {
				"noUselessFragments": "off",
				"noUselessSwitchCase": "off"
			},
			"performance": {
				"noAccumulatingSpread": "off"
			}
		}
	},
	"assist": {
		"actions": {
			"source": {
				"organizeImports": "on"
			}
		}
	},
	"overrides": [
		{
			"includes": ["packages/shared/src/**", "apps/client/src/**", "!packages/shared/src/zod.ts"],
			"linter": {
				"rules": {
					"style": {
						"noRestrictedImports": {
							"level": "error",
							"options": {
								"paths": {
									"zod": "Import zod from the shared wrapper (packages/shared/src/zod.ts) instead. It sets `jitless` so the Electron renderer's CSP does not block zod's eval-based JIT probe. Server code is exempt and may import zod directly."
								}
							}
						}
					}
				}
			}
		}
	]
}
