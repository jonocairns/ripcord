{
  "name": "@sharkord/site",
  "private": true,
  "version": "1.4.20",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc -p tsconfig.app.json --noEmit && vite build",
    "lint": "biome lint ./src",
    "lint:fix": "biome lint --fix ./src",
    "check-types": "tsc --noEmit --project tsconfig.app.json",
    "format": "biome format --write ./src",
    "preview": "vite preview"
  },
  "dependencies": {
    "react": "^19.1.0",
    "react-dom": "^19.1.0"
  },
  "devDependencies": {
    "@tailwindcss/vite": "^4.1.4",
    "@types/react": "^19.1.2",
    "@types/react-dom": "^19.1.2",
    "@vitejs/plugin-react-swc": "^3.9.0",
    "tailwindcss": "^4.1.4",
    "typescript": "^5.8.3",
    "vite": "^6.3.3"
  }
}
