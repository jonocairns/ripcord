		"@sharkord/app-core": "workspace:*",
		"@sharkord/shared": "workspace:*",
		"@shopify/flash-list": "2.0.2",
		"@trpc/client": "^11.6.0",
		"expo": "^54.0.0",
		"expo-constants": "~18.0.13",
		"expo-dev-client": "~6.0.20",
		"expo-device": "~8.0.10",
		"expo-font": "~14.0.11",
		"expo-glass-effect": "~0.1.9",
		"expo-image": "~3.0.11",
