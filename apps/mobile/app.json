{
  "expo": {
    "name": "Sharkord Mobile",
    "slug": "sharkord-mobile",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "sharkord",
    "userInterfaceStyle": "automatic",
    "ios": {
      "bundleIdentifier": "com.jonosma.sharkordmobile",
      "icon": "./assets/expo.icon",
      "bitcode": false
    },
    "android": {
      "package": "com.jonosma.sharkordmobile",
      "permissions": [
        "android.permission.MODIFY_AUDIO_SETTINGS",
        "android.permission.RECORD_AUDIO",
        "android.permission.ACCESS_NETWORK_STATE",
        "android.permission.CAMERA",
        "android.permission.INTERNET",
        "android.permission.SYSTEM_ALERT_WINDOW",
        "android.permission.WAKE_LOCK",
        "android.permission.BLUETOOTH"
      ],
      "adaptiveIcon": {
        "backgroundColor": "#E6F4FE",
        "foregroundImage": "./assets/images/android-icon-foreground.png",
        "backgroundImage": "./assets/images/android-icon-background.png",
        "monochromeImage": "./assets/images/android-icon-monochrome.png"
      },
      "predictiveBackGestureEnabled": false
    },
    "web": {
      "output": "static",
      "favicon": "./assets/images/favicon.png"
    },
    "plugins": [
      "expo-router",
      "expo-dev-client",
      "expo-notifications",
      "expo-secure-store",
      [
        "@config-plugins/react-native-webrtc",
        {
          "microphonePermission": "Allow Sharkord Mobile to access your microphone for voice channels."
        }
      ],
      [
        "expo-splash-screen",
        {
          "backgroundColor": "#208AEF",
          "android": {
            "image": "./assets/images/splash-icon.png",
            "imageWidth": 76
          }
        }
      ],
      "expo-font",
      "expo-web-browser"
    ],
    "experiments": {
      "reactCompiler": true
    },
    "extra": {
      "router": {},
      "eas": {
        "projectId": "ceac5dcf-2378-4719-89a2-51419e1bb976"
      }
    },
    "owner": "jonosma"
  }
}
