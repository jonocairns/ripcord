{
	"compilerOptions": {
		"baseUrl": ".",
		"paths": {
			"@sharkord/app-core": ["packages/app-core/src/index.ts"],
			"@sharkord/shared": ["packages/shared/src/index.ts"]
		},
		"moduleResolution": "NodeNext",
		"module": "NodeNext",
		"target": "ESNext",
		"strict": true,
		"esModuleInterop": true,
		"skipLibCheck": true
	},
	"include": ["packages/**/*", "apps/**/*", "build.ts"]
}
